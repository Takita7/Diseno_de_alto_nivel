@startuml
title Software Architecture

left to right direction

skinparam componentStyle rectangle
skinparam shadowing false

rectangle "CUDA/HIP" as CUDA
rectangle "Clang" as CLANG
rectangle "LLVM IR" as IR

rectangle "Backend" as BACK
rectangle "Assembler" as ASM
rectangle "Kernel Binary" as BIN

rectangle "Runtime" as RT
rectangle "FPGA Driver" as DRV

CUDA --> CLANG
CLANG --> IR
IR --> BACK

BACK --> ASM
ASM --> BIN

BIN --> RT
RT --> DRV

@enduml